{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "permissions": {
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(rm -r -f:*)",
      "Bash(rm -f -r:*)",
      "Bash(sudo:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(chmod -R:*)",
      "Bash(chown -R:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git checkout --:*)",
      "Bash(git restore:*)",
      "Bash(docker-compose down -v:*)",
      "Bash(docker compose down -v:*)",
      "Bash(docker volume rm:*)",
      "Bash(docker volume prune:*)",
      "Bash(docker system prune:*)",
      "Bash(docker rm -f:*)",
      "Bash(npm publish:*)",
      "Bash(npm unpublish:*)",
      "Bash(npm install -g:*)",
      "Bash(npm i -g:*)",
      "Bash(npm uninstall -g:*)",
      "Bash(npm rm -g:*)",
      "Bash(npm audit fix --force:*)",
      "Bash(npm cache clean --force:*)",
      "Bash(mvn deploy:*)",
      "Bash(./mvnw deploy:*)",
      "Bash(mvn release:*)",
      "Bash(./mvnw release:*)",
      "Bash(mvn versions:set:*)",
      "Bash(./mvnw versions:set:*)",
      "Bash(mvn dependency:purge-local-repository:*)",
      "Bash(./mvnw dependency:purge-local-repository:*)"
    ]
  }
}
